---
import GhostContentAPI from "@tryghost/content-api";
import "../styles/global.css";

const { title } = Astro.props;

const ghost = new GhostContentAPI({
  url: import.meta.env.PUBLIC_GHOST_URL,
  key: import.meta.env.PUBLIC_GHOST_CONTENT_API_KEY,
  version: "v5.0",
});

const glossarPosts = await ghost.posts.browse({
  limit: "all",
  filter: "tag:glossar",
  include: "tags",
});

glossarPosts.sort((a, b) => a.title.localeCompare(b.title, "de"));

const glossarGrouped = {};
for (const post of glossarPosts) {
  const letter = post.title.charAt(0).toUpperCase();
  if (!glossarGrouped[letter]) glossarGrouped[letter] = [];
  glossarGrouped[letter].push(post);
}
const glossarLetters = Object.keys(glossarGrouped).sort((a, b) => a.localeCompare(b, "de"));
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - PackCampus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <slot />

    <!-- Footer -->
    <footer class="border-t border-gray-100 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
        <div class="flex items-center justify-between">
          <a href="/intern-kontrolle" class="text-gray-300/40 hover:text-gray-400 transition-colors" aria-label="Dashboard">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </a>
          <p class="text-xs sm:text-sm text-gray-400">&copy; 2026 PackCampus &middot; Alle Rechte vorbehalten</p>
          <div class="w-3.5"></div>
        </div>
        <p class="mt-4 text-[11px] text-gray-300 text-center leading-relaxed max-w-xl mx-auto">
          Moderierte Lerninhalte — ausschließlich als Lernmittel für Schülerinnen und Schüler der Packmittelklassen von FRI bestimmt. Nicht zur Weiterverbreitung gedacht.
        </p>
      </div>
    </footer>

    <!-- Feedback Button -->
    <button
      onclick="toggleFeedback(true)"
      class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 w-11 h-11 sm:w-12 sm:h-12 bg-orange-500 hover:bg-orange-600 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-200 flex items-center justify-center group"
      aria-label="Feedback geben"
    >
      <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
    </button>

    <!-- Feedback Modal Backdrop -->
    <div id="feedbackBackdrop" onclick="toggleFeedback(false)" class="fixed inset-0 bg-black/40 z-[80] opacity-0 pointer-events-none transition-opacity duration-300"></div>

    <!-- Feedback Modal -->
    <div id="feedbackModal" class="fixed inset-0 z-[90] flex items-end sm:items-center justify-center sm:p-4 pointer-events-none">
      <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-2xl w-full sm:max-w-md transform translate-y-full sm:translate-y-0 sm:scale-95 opacity-0 transition-all duration-300 pointer-events-auto max-h-[90vh] overflow-y-auto" id="feedbackCard" style="display:none">
        <div class="flex items-center justify-between px-5 sm:px-6 py-4 sm:py-5 border-b border-gray-100">
          <h2 class="text-lg font-semibold tracking-tight">Feedback geben</h2>
          <button onclick="toggleFeedback(false)" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <form id="feedbackForm" class="p-4 sm:p-6 space-y-3 sm:space-y-4">
          <!-- Type selector -->
          <div class="flex gap-2" id="feedbackTypes">
            <button type="button" data-type="lob" class="feedback-type-btn flex-1 py-2.5 px-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">
              Lob
            </button>
            <button type="button" data-type="fehler" class="feedback-type-btn flex-1 py-2.5 px-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">
              Fehler
            </button>
            <button type="button" data-type="vorschlag" class="feedback-type-btn flex-1 py-2.5 px-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">
              Vorschlag
            </button>
          </div>

          <!-- Name + Klasse row -->
          <div class="grid grid-cols-2 gap-3">
            <input
              id="feedbackName"
              type="text"
              placeholder="Name *"
              autocomplete="name"
              class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200/60 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 focus:bg-white transition-all"
            />
            <input
              id="feedbackKlasse"
              type="text"
              placeholder="Klasse *"
              autocomplete="off"
              class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200/60 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 focus:bg-white transition-all"
            />
          </div>

          <!-- Email -->
          <input
            id="feedbackEmail"
            type="email"
            placeholder="E-Mail *"
            autocomplete="email"
            class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200/60 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 focus:bg-white transition-all"
          />

          <!-- Honeypot (invisible to humans) -->
          <div class="absolute -left-[9999px]" aria-hidden="true">
            <input id="feedbackWebsite" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Message -->
          <textarea
            id="feedbackMessage"
            rows="3"
            placeholder="Was möchtest du mir mitteilen? (mind. 10 Zeichen) *"
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200/60 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 focus:bg-white transition-all resize-none"
          ></textarea>

          <!-- Status -->
          <div id="feedbackStatus" class="hidden text-sm text-center py-2 rounded-xl"></div>

          <!-- Submit -->
          <button
            type="submit"
            id="feedbackSubmit"
            class="w-full py-3 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Absenden
          </button>

          <p class="text-xs text-gray-400 text-center">Max. 5 Feedbacks pro Stunde</p>
        </form>
      </div>
    </div>

    <!-- Backdrop -->
    <div id="backdrop" onclick="toggleGlossary(false)" class="fixed inset-0 bg-black/40 z-[60] opacity-0 pointer-events-none transition-opacity duration-300"></div>

    <!-- Glossary Side Panel -->
    <aside id="glossaryPanel" class="premium-glossary fixed top-0 right-0 bottom-0 w-full md:w-[450px] bg-white z-[70] translate-x-full transition-transform duration-300 ease-out shadow-2xl flex flex-col">
      <!-- Panel Header -->
      <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold tracking-tight">Glossar</h2>
        </div>
        <button onclick="toggleGlossary(false)" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Panel Search -->
      <div class="shrink-0 bg-white relative z-20 px-5 pt-4 pb-3">
        <div class="relative">
          <i data-lucide="search" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none"></i>
          <input
            id="panel-search"
            type="text"
            autocomplete="off"
            placeholder="Fachbegriff suchen..."
            class="w-full bg-gray-50 border border-transparent rounded-2xl py-3.5 pl-11 pr-4 text-sm text-gray-900 placeholder-gray-400 outline-none focus:bg-white focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all"
          />
        </div>
      </div>

      <!-- Panel Content -->
      <div class="premium-scroll flex-1 overflow-y-auto px-2 pb-8 relative z-10" id="panel-content">
        {glossarLetters.length > 0 ? (
          <div>
            {glossarLetters.map((letter) => (
              <div class="glossar-letter-group" id={`panel-letter-${letter}`}>
                <div class="sticky top-0 bg-white/90 backdrop-blur-md px-4 py-2 mb-1 z-10 flex items-center gap-3">
                  <span class="text-2xl font-black text-orange-500">{letter}</span>
                  <div class="h-px bg-gray-100 flex-grow mt-1"></div>
                </div>
                {glossarGrouped[letter].map((post) => (
                  <details
                    class="glossar-panel-entry group px-2"
                    data-slug={post.slug}
                    data-title={post.title.toLowerCase()}
                  >
                    <summary class="flex items-center justify-between py-3 px-2 cursor-pointer rounded-xl hover:bg-gray-50 transition-colors select-none group-open:bg-orange-50/50 group-open:text-orange-600">
                      <span class="font-bold text-[15px] text-gray-800 group-open:text-orange-700 transition-colors">{post.title}</span>
                      <i data-lucide="plus" class="w-4 h-4 text-gray-400 group-open:hidden flex-shrink-0 ml-4"></i>
                      <i data-lucide="minus" class="w-4 h-4 text-orange-500 hidden group-open:block flex-shrink-0 ml-4"></i>
                    </summary>
                    <div class="px-2 pb-4 pt-1">
                      <div
                        class="pl-4 border-l-2 border-orange-200 text-sm text-gray-600 leading-relaxed"
                        set:html={post.html}
                      />
                    </div>
                  </details>
                ))}
              </div>
            ))}
          </div>
        ) : (
          <div class="px-6 py-16 text-center">
            <p class="text-sm text-gray-400">Noch keine Glossareinträge vorhanden.</p>
          </div>
        )}
        <div id="panel-no-results" class="hidden px-6 py-16 text-center">
          <i data-lucide="search-x" class="w-10 h-10 text-gray-200 mx-auto mb-4"></i>
          <p class="text-sm text-gray-400">Kein Fachbegriff gefunden.</p>
        </div>
      </div>
    </aside>

    <!-- Feedback toggle (inline for immediate availability) -->
    <script is:inline>
      function toggleMobileNav() {
        var nav = document.getElementById('mobileNav');
        if (nav) nav.classList.toggle('hidden');
      }

      function toggleFeedback(isOpen) {
        var backdrop = document.getElementById('feedbackBackdrop');
        var card = document.getElementById('feedbackCard');
        var isMobile = window.innerWidth < 640;
        if (isOpen) {
          card.style.display = '';
          requestAnimationFrame(function() {
            backdrop.classList.remove('opacity-0', 'pointer-events-none');
            backdrop.classList.add('opacity-100');
            if (isMobile) {
              card.classList.remove('translate-y-full', 'opacity-0');
              card.classList.add('translate-y-0', 'opacity-100');
            } else {
              card.classList.remove('scale-95', 'opacity-0');
              card.classList.add('scale-100', 'opacity-100');
            }
          });
        } else {
          backdrop.classList.add('opacity-0', 'pointer-events-none');
          backdrop.classList.remove('opacity-100');
          if (isMobile) {
            card.classList.add('translate-y-full', 'opacity-0');
            card.classList.remove('translate-y-0', 'opacity-100');
          } else {
            card.classList.add('scale-95', 'opacity-0');
            card.classList.remove('scale-100', 'opacity-100');
          }
          setTimeout(function() { card.style.display = 'none'; }, 300);
        }
      }
    </script>

    <!-- Feedback form logic -->
    <script>
      const feedbackForm = document.getElementById("feedbackForm");
      const feedbackName = document.getElementById("feedbackName") as HTMLInputElement;
      const feedbackKlasse = document.getElementById("feedbackKlasse") as HTMLInputElement;
      const feedbackEmail = document.getElementById("feedbackEmail") as HTMLInputElement;
      const feedbackMessage = document.getElementById("feedbackMessage") as HTMLTextAreaElement;
      const feedbackWebsite = document.getElementById("feedbackWebsite") as HTMLInputElement;
      const feedbackStatus = document.getElementById("feedbackStatus")!;
      const feedbackSubmit = document.getElementById("feedbackSubmit") as HTMLButtonElement;
      const typeButtons = document.querySelectorAll(".feedback-type-btn");
      let selectedType = "";
      let modalOpenedAt = 0;

      // Track when modal opens for minimum time check
      const origToggle = (window as any).toggleFeedback;
      (window as any).toggleFeedback = function (isOpen: boolean) {
        if (isOpen) modalOpenedAt = Date.now();
        origToggle(isOpen);
      };

      typeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          selectedType = (btn as HTMLElement).dataset.type || "";
          typeButtons.forEach((b) => {
            b.classList.remove("border-orange-500", "bg-orange-50", "text-orange-600");
            b.classList.add("border-gray-200", "text-gray-600");
          });
          btn.classList.add("border-orange-500", "bg-orange-50", "text-orange-600");
          btn.classList.remove("border-gray-200", "text-gray-600");
        });
      });

      feedbackForm?.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Minimum time check (3 seconds)
        if (Date.now() - modalOpenedAt < 3000) {
          showStatus("Bitte nimm dir einen Moment Zeit für dein Feedback.", "error");
          return;
        }

        const name = feedbackName?.value.trim();
        const klasse = feedbackKlasse?.value.trim();
        const email = feedbackEmail?.value.trim();
        const message = feedbackMessage?.value.trim();

        if (!selectedType) {
          showStatus("Bitte wähle einen Feedback-Typ.", "error");
          return;
        }
        if (!name || !klasse || !email) {
          showStatus("Bitte fülle alle Felder aus.", "error");
          return;
        }
        if (!message || message.length < 10) {
          showStatus("Die Nachricht muss mindestens 10 Zeichen haben.", "error");
          return;
        }

        feedbackSubmit.disabled = true;
        feedbackSubmit.textContent = "Wird gesendet...";

        try {
          const res = await fetch("/api/feedback", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              type: selectedType,
              name,
              klasse,
              email,
              message,
              url: window.location.pathname,
              website: feedbackWebsite?.value || "",
            }),
          });

          const data = await res.json();

          if (!res.ok) {
            showStatus(data.error || "Senden fehlgeschlagen.", "error");
            return;
          }

          showStatus("Danke für dein Feedback!", "success");
          feedbackMessage.value = "";
          feedbackName.value = "";
          feedbackKlasse.value = "";
          feedbackEmail.value = "";
          selectedType = "";
          typeButtons.forEach((b) => {
            b.classList.remove("border-orange-500", "bg-orange-50", "text-orange-600");
            b.classList.add("border-gray-200", "text-gray-600");
          });

          setTimeout(() => (window as any).toggleFeedback(false), 1500);
        } catch {
          showStatus("Senden fehlgeschlagen. Bitte versuche es erneut.", "error");
        } finally {
          feedbackSubmit.disabled = false;
          feedbackSubmit.textContent = "Absenden";
        }
      });

      function showStatus(msg: string, type: "success" | "error") {
        feedbackStatus.textContent = msg;
        feedbackStatus.classList.remove("hidden", "text-green-600", "bg-green-50", "text-red-600", "bg-red-50");
        if (type === "success") {
          feedbackStatus.classList.add("text-green-600", "bg-green-50");
        } else {
          feedbackStatus.classList.add("text-red-600", "bg-red-50");
        }
      }
    </script>

    <!-- Glossary toggle & panel search (inline for immediate availability) -->
    <script is:inline>
      function toggleGlossary(isOpen) {
        var panel = document.getElementById('glossaryPanel');
        var backdrop = document.getElementById('backdrop');
        if (isOpen) {
          panel.classList.remove('translate-x-full');
          panel.classList.add('translate-x-0');
          backdrop.classList.remove('opacity-0', 'pointer-events-none');
          backdrop.classList.add('opacity-100');
          document.body.classList.add('overflow-hidden');
        } else {
          panel.classList.add('translate-x-full');
          panel.classList.remove('translate-x-0');
          backdrop.classList.add('opacity-0', 'pointer-events-none');
          backdrop.classList.remove('opacity-100');
          document.body.classList.remove('overflow-hidden');
        }
      }

      function openGlossaryTerm(slug) {
        toggleGlossary(true);
        setTimeout(function() {
          var entry = document.querySelector('[data-slug="' + slug + '"]');
          if (entry) {
            entry.open = true;
            entry.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }, 350);
      }
    </script>

    <!-- Panel search filtering + accordion (module script) -->
    <script>
      const panelSearch = document.getElementById("panel-search");
      const panelEntries = document.querySelectorAll(".glossar-panel-entry");
      const panelGroups = document.querySelectorAll(".glossar-letter-group");
      const panelNoResults = document.getElementById("panel-no-results");
      const panelContentInner = document.querySelector("#panel-content > div:first-child");

      // Akkordeon: nur ein Begriff gleichzeitig offen
      panelEntries.forEach(targetDetail => {
        targetDetail.addEventListener("click", () => {
          if (!targetDetail.open) {
            panelEntries.forEach(detail => {
              if (detail !== targetDetail && detail.open) {
                detail.removeAttribute("open");
              }
            });
          }
        });
      });

      if (panelSearch) {
        panelSearch.addEventListener("input", () => {
          const q = panelSearch.value.trim().toLowerCase();
          let total = 0;

          panelEntries.forEach((entry) => {
            const title = entry.dataset.title || "";
            const match = !q || title.includes(q);
            entry.style.display = match ? "" : "none";
            if (match) total++;
          });

          panelGroups.forEach((group) => {
            const visible = group.querySelectorAll('.glossar-panel-entry:not([style*="display: none"])').length;
            group.style.display = visible > 0 ? "" : "none";
          });

          if (panelNoResults) {
            panelNoResults.classList.toggle("hidden", total > 0 || !q);
          }
          if (panelContentInner) {
            panelContentInner.classList.toggle("hidden", total === 0 && !!q);
          }
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          const panel = document.getElementById("glossaryPanel");
          if (panel && !panel.classList.contains("translate-x-full")) {
            toggleGlossary(false);
          }
        }
      });
    </script>

    <!-- Audio card redesign -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".kg-audio-card").forEach((card) => {
          const audio = card.querySelector("audio");
          if (!audio) return;

          const audioSrc = audio.src || audio.querySelector("source")?.src || "";
          const titleEl = card.querySelector(".kg-audio-title");
          const audioTitle = titleEl?.textContent?.trim() || "Audio";

          card.innerHTML = `
            <div class="bg-gray-900 rounded-[2rem] p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-xl my-8 border border-gray-800 relative overflow-hidden">
              <div class="absolute -right-10 -top-10 w-40 h-40 bg-orange-500 rounded-full blur-3xl opacity-20 pointer-events-none"></div>
              <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-orange-500/30 relative z-10">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
              </div>
              <div class="flex-grow w-full relative z-10">
                <h4 class="text-white font-black text-lg mb-1 leading-tight">${audioTitle}</h4>
                <p class="text-orange-500 text-[10px] uppercase tracking-[0.2em] font-bold mb-4">PackCampus Audio</p>
                <audio controls class="w-full h-12 rounded-full shadow-inner" src="${audioSrc}" preload="metadata"></audio>
              </div>
            </div>
          `;

          card.classList.remove("kg-audio-card");
          card.classList.add("packcampus-audio-player");
        });
      });
    </script>

    <!-- Lucide icons + KaTeX rendering -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function() {
        // ── Slideshow Parser ──
        (function initSlideshows() {
          var allP = document.querySelectorAll("p");
          var startMarkers = [];
          for (var si = 0; si < allP.length; si++) {
            if (allP[si].textContent.trim().indexOf("[slideshow:") === 0) {
              startMarkers.push(allP[si]);
            }
          }

          for (var m = 0; m < startMarkers.length; m++) {
            var startEl = startMarkers[m];
            var titleText = startEl.textContent.trim()
              .replace("[slideshow:", "").replace("]", "").trim();

            // Collect slides (array of arrays of DOM nodes)
            var slidesContent = [[]];
            var toRemove = [];
            var current = startEl.nextElementSibling;
            var endMarker = null;

            while (current) {
              var next = current.nextElementSibling;
              if (current.textContent.trim() === "[/slideshow]") {
                endMarker = current;
                break;
              }
              if (current.tagName === "HR") {
                slidesContent.push([]);
                toRemove.push(current);
              } else {
                slidesContent[slidesContent.length - 1].push(current);
              }
              current = next;
            }

            if (!endMarker) continue;

            var totalSlides = slidesContent.length;

            // Remove collected elements from DOM (don't destroy them, just detach)
            for (var r = 0; r < toRemove.length; r++) {
              toRemove[r].parentNode.removeChild(toRemove[r]);
            }
            if (endMarker) endMarker.parentNode.removeChild(endMarker);

            // Build container
            var container = document.createElement("div");
            container.className = "not-prose bg-white rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 p-6 md:p-10 flex flex-col relative my-10";

            // Header row
            var header = document.createElement("div");
            header.className = "flex items-center justify-between mb-4";

            var titleDiv = document.createElement("div");
            titleDiv.className = "flex items-center gap-2 font-bold text-gray-800";
            titleDiv.innerHTML = '<i data-lucide="book-open" class="w-5 h-5 text-orange-500"></i> ' + titleText;

            var stepPill = document.createElement("span");
            stepPill.className = "bg-orange-50 text-orange-600 font-bold text-xs tracking-widest uppercase px-4 py-1.5 rounded-full";
            stepPill.textContent = "Schritt 1 / " + totalSlides;

            header.appendChild(titleDiv);
            header.appendChild(stepPill);
            container.appendChild(header);

            // Progress bar
            var progressOuter = document.createElement("div");
            progressOuter.className = "h-1.5 w-full bg-gray-100 rounded-full mb-10";
            var progressInner = document.createElement("div");
            progressInner.className = "bg-orange-500 h-full rounded-full transition-all duration-500";
            progressInner.style.width = (1 / totalSlides * 100) + "%";
            progressOuter.appendChild(progressInner);
            container.appendChild(progressOuter);

            // Slides wrapper
            var wrapper = document.createElement("div");
            wrapper.className = "pc-slides-wrapper";

            for (var s = 0; s < slidesContent.length; s++) {
              var slide = document.createElement("div");
              slide.className = "pc-slide-item" + (s === 0 ? " is-active" : "");
              for (var c = 0; c < slidesContent[s].length; c++) {
                slide.appendChild(slidesContent[s][c]);
              }
              wrapper.appendChild(slide);
            }
            container.appendChild(wrapper);

            // Footer with navigation buttons
            var footer = document.createElement("div");
            footer.className = "flex items-center justify-between mt-10";

            var btnBack = document.createElement("button");
            btnBack.className = "px-6 py-3 rounded-2xl font-bold text-sm text-gray-400 bg-gray-100 transition-all cursor-not-allowed";
            btnBack.innerHTML = '<span class="flex items-center gap-2"><i data-lucide="arrow-left" class="w-4 h-4"></i> Zurück</span>';
            btnBack.disabled = true;

            var btnNext = document.createElement("button");
            btnNext.className = "px-8 py-3.5 rounded-2xl font-bold text-sm text-white bg-gray-900 hover:bg-orange-500 transition-all shadow-lg hover:-translate-y-0.5";
            btnNext.innerHTML = '<span class="flex items-center gap-2">Weiter <i data-lucide="arrow-right" class="w-4 h-4"></i></span>';

            footer.appendChild(btnBack);
            footer.appendChild(btnNext);
            container.appendChild(footer);

            // Insert container where start marker was
            startEl.parentNode.replaceChild(container, startEl);

            // State logic (closure)
            (function(cont, pill, progInner, back, next, total) {
              var currentSlide = 0;
              var slides = cont.querySelectorAll(".pc-slide-item");

              function update() {
                pill.textContent = "Schritt " + (currentSlide + 1) + " / " + total;
                progInner.style.width = ((currentSlide + 1) / total * 100) + "%";

                for (var i = 0; i < slides.length; i++) {
                  if (i === currentSlide) {
                    slides[i].classList.add("is-active");
                  } else {
                    slides[i].classList.remove("is-active");
                  }
                }

                // Back button state
                if (currentSlide === 0) {
                  back.disabled = true;
                  back.className = "px-6 py-3 rounded-2xl font-bold text-sm text-gray-400 bg-gray-100 transition-all cursor-not-allowed";
                } else {
                  back.disabled = false;
                  back.className = "px-6 py-3 rounded-2xl font-bold text-sm text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all cursor-pointer";
                }

                // Next button state
                if (currentSlide === total - 1) {
                  next.innerHTML = '<span class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4"></i> Fertig</span>';
                  next.className = "px-8 py-3.5 rounded-2xl font-bold text-sm text-white bg-green-500 hover:bg-green-600 transition-all shadow-lg hover:-translate-y-0.5";
                } else {
                  next.innerHTML = '<span class="flex items-center gap-2">Weiter <i data-lucide="arrow-right" class="w-4 h-4"></i></span>';
                  next.className = "px-8 py-3.5 rounded-2xl font-bold text-sm text-white bg-gray-900 hover:bg-orange-500 transition-all shadow-lg hover:-translate-y-0.5";
                }

                // Re-render lucide icons inside this container
                if (typeof lucide !== "undefined" && lucide.createIcons) {
                  lucide.createIcons();
                }
              }

              back.addEventListener("click", function() {
                if (currentSlide > 0) {
                  currentSlide--;
                  update();
                }
              });

              next.addEventListener("click", function() {
                if (currentSlide < total - 1) {
                  currentSlide++;
                  update();
                }
              });
            })(container, stepPill, progressInner, btnBack, btnNext, totalSlides);
          }
        })();

        // Render Lucide icons
        if (typeof lucide !== "undefined" && lucide.createIcons) {
          lucide.createIcons();
        }

        // Render KaTeX formulas (AFTER callout DOM is ready)
        if (typeof renderMathInElement !== "undefined") {
          renderMathInElement(document.body, {
            delimiters: [
              { left: "$$", right: "$$", display: true },
              { left: "$", right: "$", display: false }
            ],
            throwOnError: false
          });
        } else {
          console.warn("KaTeX konnte nicht geladen werden.");
        }
      });
    </script>
  </body>
</html>
