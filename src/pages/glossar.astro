---
import Layout from "../layouts/Layout.astro";
import GhostContentAPI from "@tryghost/content-api";

const ghost = new GhostContentAPI({
  url: import.meta.env.PUBLIC_GHOST_URL,
  key: import.meta.env.PUBLIC_GHOST_CONTENT_API_KEY,
  version: "v5.0",
});

const posts = await ghost.posts.browse({
  limit: "all",
  filter: "tag:glossar",
  include: "tags",
});

posts.sort((a, b) => a.title.localeCompare(b.title, "de"));

const grouped = {};
for (const post of posts) {
  const letter = post.title.charAt(0).toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(post);
}

const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, "de"));
---

<Layout title="Glossar">
  <!-- Header -->
  <header class="bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 sm:w-9 sm:h-9 bg-orange-500 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <span class="text-base sm:text-lg font-semibold tracking-tight">PackCampus</span>
      </a>
      <div class="flex items-center gap-2">
        <button onclick="toggleGlossary(true)" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors text-orange-500 cursor-pointer" aria-label="Glossar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </button>
        <a href="/" class="hidden sm:flex items-center gap-2 text-sm text-gray-400 hover:text-orange-500 transition-colors font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Themen
        </a>
      </div>
  </header>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16 pb-6 sm:pb-10">
    <p class="text-xs sm:text-sm font-medium text-orange-500 tracking-wide uppercase mb-2 sm:mb-3">Nachschlagewerk</p>
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight">
      Glossar
    </h1>
    <p class="mt-3 sm:mt-4 text-base sm:text-lg text-gray-500 max-w-2xl leading-relaxed">
      Wichtige Fachbegriffe aus der Welt der Packmitteltechnologie — alphabetisch sortiert und verständlich erklärt.
    </p>
  </section>

  <!-- Premium Glossar Container -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 sm:pb-24">
    <div class="premium-glossary bg-white rounded-3xl border border-gray-200/60 shadow-sm h-[750px] max-h-[90vh] flex flex-col overflow-hidden">

      <!-- Fixe Suchleiste -->
      <div class="shrink-0 bg-white relative z-20 px-5 pt-5 pb-3">
        <div class="relative">
          <i data-lucide="search" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none"></i>
          <input
            id="glossar-search"
            type="text"
            autocomplete="off"
            placeholder="Fachbegriff suchen..."
            class="w-full bg-gray-50 border border-transparent rounded-2xl py-3.5 pl-11 pr-4 text-sm text-gray-900 placeholder-gray-400 outline-none focus:bg-white focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10 transition-all"
          />
        </div>
      </div>

      <!-- No results -->
      <div id="glossar-no-results" class="hidden flex-grow flex items-center justify-center">
        <div class="text-center py-16">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <i data-lucide="search-x" class="w-7 h-7 text-gray-300"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-400 mb-1">Keine Ergebnisse</h3>
          <p class="text-sm text-gray-400">Versuche einen anderen Suchbegriff.</p>
        </div>
      </div>

      <!-- Scrollbarer Bereich -->
      <div id="glossar-entries" class="premium-scroll overflow-y-auto flex-grow px-2 pb-8 relative z-10">
        {letters.length > 0 ? (
          <>
            {letters.map((letter) => (
              <div class="letter-group">
                <div class="sticky top-0 bg-white/90 backdrop-blur-md px-4 py-2 mb-1 z-10 flex items-center gap-3">
                  <span class="text-2xl font-black text-brand-500">{letter}</span>
                  <div class="h-px bg-gray-100 flex-grow mt-1"></div>
                </div>
                {grouped[letter].map((post) => (
                  <details class="glossar-entry group px-2" data-title={post.title.toLowerCase()} data-excerpt={(post.excerpt || "").toLowerCase()}>
                    <summary class="flex items-center justify-between py-3 px-2 cursor-pointer rounded-xl hover:bg-gray-50 transition-colors select-none group-open:bg-brand-50/50 group-open:text-brand-600">
                      <span class="font-bold text-[15px] text-gray-800 group-open:text-brand-700 transition-colors">{post.title}</span>
                      <i data-lucide="plus" class="w-4 h-4 text-gray-400 group-open:hidden flex-shrink-0 ml-4"></i>
                      <i data-lucide="minus" class="w-4 h-4 text-brand-500 hidden group-open:block flex-shrink-0 ml-4"></i>
                    </summary>
                    <div class="px-2 pb-4 pt-1">
                      <div class="pl-4 border-l-2 border-brand-200 text-sm text-gray-600 leading-relaxed" set:html={post.html} />
                    </div>
                  </details>
                ))}
              </div>
            ))}
          </>
        ) : (
          <div class="text-center py-20">
            <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
              <i data-lucide="book-open" class="w-8 h-8 text-gray-300"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-400 mb-2">Noch keine Glossareinträge</h3>
            <p class="text-sm text-gray-400">Erstelle Beiträge in Ghost mit dem Tag "Glossar", um Fachbegriffe hier anzuzeigen.</p>
          </div>
        )}
      </div>

    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Akkordeon: nur ein Begriff gleichzeitig offen
      const detailsElements = document.querySelectorAll('.premium-glossary details');
      detailsElements.forEach(targetDetail => {
        targetDetail.addEventListener('click', () => {
          if (!targetDetail.open) {
            detailsElements.forEach(detail => {
              if (detail !== targetDetail && detail.open) {
                detail.removeAttribute('open');
              }
            });
          }
        });
      });

      // Suche
      const glossarInput = document.getElementById("glossar-search");
      const glossarEntries = document.querySelectorAll(".glossar-entry");
      const letterGroups = document.querySelectorAll(".letter-group");
      const entriesSection = document.getElementById("glossar-entries");
      const glossarNoResults = document.getElementById("glossar-no-results");

      if (glossarInput) {
        glossarInput.addEventListener("input", () => {
          const q = glossarInput.value.trim().toLowerCase();
          let totalVisible = 0;

          glossarEntries.forEach((entry) => {
            const title = entry.dataset.title || "";
            const excerpt = entry.dataset.excerpt || "";
            const match = !q || title.includes(q) || excerpt.includes(q);
            entry.style.display = match ? "" : "none";
            if (match) totalVisible++;
          });

          letterGroups.forEach((group) => {
            const visibleInGroup = group.querySelectorAll('.glossar-entry:not([style*="display: none"])').length;
            group.style.display = visibleInGroup > 0 ? "" : "none";
          });

          if (glossarNoResults) {
            glossarNoResults.classList.toggle("hidden", totalVisible > 0 || !q);
          }
          if (entriesSection) {
            entriesSection.classList.toggle("hidden", totalVisible === 0 && !!q);
          }
        });
      }

      // Lucide Icons rendern
      if (typeof lucide !== "undefined" && lucide.createIcons) {
        lucide.createIcons();
      }
    });
  </script>
</Layout>
