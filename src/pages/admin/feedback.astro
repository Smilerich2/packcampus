---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Feedback-Übersicht">
  <header class="bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 sm:w-9 sm:h-9 bg-orange-500 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <span class="text-base sm:text-lg font-semibold tracking-tight">PackCampus</span>
      </a>
      <a href="/intern-kontrolle" class="flex items-center gap-2 text-xs sm:text-sm text-gray-400 hover:text-orange-500 transition-colors font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Dashboard
      </a>
    </div>
  </header>

  <!-- Login Gate -->
  <div id="loginGate" class="min-h-[60vh] flex items-center justify-center px-4 sm:px-6">
    <div class="w-full max-w-sm">
      <div class="bg-white rounded-3xl border border-gray-200/60 shadow-sm p-6 sm:p-8">
        <div class="w-12 h-12 bg-orange-50 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-center text-gray-900 mb-1">Geschützter Bereich</h2>
        <p class="text-sm text-gray-400 text-center mb-6">Bitte Passwort eingeben</p>
        <form id="loginForm" class="space-y-4">
          <input
            id="loginPassword"
            type="password"
            placeholder="Passwort"
            autocomplete="current-password"
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200/60 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 focus:bg-white transition-all"
          />
          <div id="loginError" class="hidden text-sm text-red-600 bg-red-50 text-center py-2 rounded-xl"></div>
          <button
            type="submit"
            class="w-full py-3 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold rounded-xl transition-colors"
          >
            Anmelden
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Feedback Content (hidden until auth) -->
  <div id="feedbackContent" class="hidden">
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-8 sm:pt-12 pb-4 sm:pb-6">
      <div class="flex flex-col gap-4">
        <div>
          <p class="text-xs sm:text-sm font-medium text-orange-500 tracking-wide uppercase mb-2 sm:mb-3">Verwaltung</p>
          <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-gray-900">Schüler-Feedback</h1>
        </div>
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <span id="feedbackCount" class="text-xs sm:text-sm text-gray-400 w-full sm:w-auto"></span>
          <div class="flex flex-wrap gap-1.5" id="filterButtons">
            <button data-filter="alle" class="filter-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm font-medium bg-orange-500 text-white transition-all cursor-pointer">Alle</button>
            <button data-filter="lob" class="filter-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">Lob</button>
            <button data-filter="fehler" class="filter-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">Fehler</button>
            <button data-filter="vorschlag" class="filter-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:border-orange-300 hover:text-orange-600 transition-all cursor-pointer">Vorschlag</button>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 sm:pb-24">
      <div id="feedbackList" class="space-y-3"></div>
      <div id="feedbackEmpty" class="hidden text-center py-20">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-400 mb-2">Noch kein Feedback</h3>
        <p class="text-sm text-gray-400">Sobald Schüler Feedback senden, erscheint es hier.</p>
      </div>
    </section>
  </div>

  <script>
    const loginForm = document.getElementById("loginForm");
    const loginPassword = document.getElementById("loginPassword") as HTMLInputElement;
    const loginError = document.getElementById("loginError")!;
    const loginGate = document.getElementById("loginGate")!;
    const feedbackContent = document.getElementById("feedbackContent")!;
    const feedbackList = document.getElementById("feedbackList")!;
    const feedbackEmpty = document.getElementById("feedbackEmpty")!;
    const feedbackCount = document.getElementById("feedbackCount")!;
    const filterButtons = document.querySelectorAll(".filter-btn");

    let allFeedback: any[] = [];
    let currentFilter = "alle";
    let authToken = "";

    // Check session
    const stored = sessionStorage.getItem("admin_token");
    if (stored) {
      authToken = stored;
      authenticate(stored);
    }

    loginForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const pw = loginPassword?.value;
      if (!pw) return;

      try {
        const res = await fetch("/api/auth", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password: pw }),
        });
        const data = await res.json();

        if (!res.ok) {
          loginError.textContent = data.error || "Fehler bei der Anmeldung.";
          loginError.classList.remove("hidden");
          return;
        }

        authToken = data.token;
        sessionStorage.setItem("admin_token", authToken);
        authenticate(authToken);
      } catch {
        loginError.textContent = "Verbindung fehlgeschlagen.";
        loginError.classList.remove("hidden");
      }
    });

    async function authenticate(token: string) {
      try {
        const res = await fetch("/api/feedback-list", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token }),
        });

        if (!res.ok) {
          sessionStorage.removeItem("admin_token");
          return;
        }

        allFeedback = await res.json();
        allFeedback.reverse(); // newest first

        loginGate.classList.add("hidden");
        feedbackContent.classList.remove("hidden");
        renderFeedback();
      } catch {
        sessionStorage.removeItem("admin_token");
      }
    }

    // Filter buttons
    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        currentFilter = (btn as HTMLElement).dataset.filter || "alle";
        filterButtons.forEach((b) => {
          b.classList.remove("bg-orange-500", "text-white");
          b.classList.add("bg-white", "border", "border-gray-200", "text-gray-600");
        });
        btn.classList.add("bg-orange-500", "text-white");
        btn.classList.remove("bg-white", "border", "border-gray-200", "text-gray-600");
        renderFeedback();
      });
    });

    const typeLabels: Record<string, { label: string; color: string; bg: string }> = {
      lob: { label: "Lob", color: "text-emerald-700", bg: "bg-emerald-50 border-emerald-200" },
      fehler: { label: "Fehler", color: "text-red-700", bg: "bg-red-50 border-red-200" },
      vorschlag: { label: "Vorschlag", color: "text-blue-700", bg: "bg-blue-50 border-blue-200" },
    };

    function renderFeedback() {
      const filtered = currentFilter === "alle"
        ? allFeedback
        : allFeedback.filter((f) => f.type === currentFilter);

      feedbackCount.textContent = `${filtered.length} von ${allFeedback.length} Einträgen`;

      if (filtered.length === 0) {
        feedbackList.innerHTML = "";
        feedbackEmpty.classList.remove("hidden");
        return;
      }

      feedbackEmpty.classList.add("hidden");
      feedbackList.innerHTML = filtered
        .map((f) => {
          const t = typeLabels[f.type] || { label: f.type, color: "text-gray-700", bg: "bg-gray-50 border-gray-200" };
          const date = new Date(f.timestamp).toLocaleDateString("de-DE", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          });

          return `
            <div class="bg-white rounded-2xl border border-gray-200/60 shadow-sm p-4 sm:p-6 hover:shadow-md transition-shadow">
              <div class="flex flex-wrap items-center gap-2 sm:gap-3 mb-3">
                <span class="inline-flex px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-lg text-xs font-semibold border ${t.bg} ${t.color}">${t.label}</span>
                <span class="text-xs text-gray-400">${date}</span>
                ${f.url ? `<span class="text-xs text-gray-400 font-mono bg-gray-50 px-2 py-0.5 rounded truncate max-w-[10rem] sm:max-w-none">${f.url}</span>` : ""}
              </div>
              <p class="text-sm text-gray-700 leading-relaxed mb-3 sm:mb-4">${escapeHtml(f.message)}</p>
              <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-xs text-gray-400">
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  ${escapeHtml(f.name || "–")}
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                  ${escapeHtml(f.klasse || "–")}
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  ${escapeHtml(f.email || "–")}
                </span>
              </div>
            </div>
          `;
        })
        .join("");
    }

    function escapeHtml(str: string): string {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }
  </script>
</Layout>
