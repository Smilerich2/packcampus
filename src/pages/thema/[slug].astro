---
import Layout from "../../layouts/Layout.astro";
import GhostContentAPI from "@tryghost/content-api";

const ghost = new GhostContentAPI({
  url: import.meta.env.PUBLIC_GHOST_URL,
  key: import.meta.env.PUBLIC_GHOST_CONTENT_API_KEY,
  version: "v5.0",
});

const { slug } = Astro.params;

const tag = await ghost.tags.read({ slug }, { include: "count.posts" });

const posts = await ghost.posts.browse({
  limit: "all",
  filter: `tag:${slug}+tag:-glossar`,
  include: "tags,authors",
});
---

<Layout title={tag.name}>
  <!-- Header -->
  <header class="bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <div class="w-9 h-9 bg-orange-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <span class="text-lg font-semibold tracking-tight">PackCampus</span>
      </a>
      <nav class="flex items-center gap-6">
        <button onclick="toggleGlossary(true)" class="text-sm text-gray-400 hover:text-orange-500 transition-colors font-medium cursor-pointer">Glossar</button>
        <a href="/" class="flex items-center gap-2 text-sm text-gray-400 hover:text-orange-500 transition-colors font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Themen
        </a>
      </nav>
    </div>
  </header>

  <!-- Tag Hero -->
  {tag.feature_image ? (
    <section class="relative overflow-hidden">
      <div class="relative h-64 md:h-80">
        <img src={tag.feature_image} alt={tag.name} class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/40 to-gray-900/20" />
        <div class="absolute inset-0 bg-gradient-to-r from-gray-900/30 to-transparent" />
        <div class="absolute inset-0 flex flex-col justify-end">
          <div class="max-w-6xl mx-auto px-6 pb-8 w-full">
            <div class="flex items-center gap-2 text-sm text-white/50 mb-4">
              <a href="/" class="hover:text-white/80 transition-colors">Themen</a>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span class="text-white/70 font-medium">{tag.name}</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white leading-tight drop-shadow-sm">{tag.name}</h1>
            {tag.description && (
              <p class="mt-3 text-base md:text-lg text-white/70 max-w-2xl leading-relaxed">{tag.description}</p>
            )}
            <div class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-white/90 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              {posts.length} {posts.length === 1 ? "Lektion" : "Lektionen"}
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-6">
          <a href="/" class="hover:text-orange-500 transition-colors">Themen</a>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <span class="text-gray-600 font-medium">{tag.name}</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight">{tag.name}</h1>
        {tag.description && (
          <p class="mt-4 text-lg text-gray-500 max-w-2xl leading-relaxed">{tag.description}</p>
        )}
        <div class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-orange-600 bg-orange-50 rounded-full px-4 py-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          {posts.length} {posts.length === 1 ? "Lektion" : "Lektionen"}
        </div>
      </div>
      <div class="max-w-6xl mx-auto px-6">
        <div class="h-px bg-gradient-to-r from-orange-300 via-orange-100 to-transparent" />
      </div>
    </section>
  )}

  <!-- Posts Grid -->
  <section class="max-w-6xl mx-auto px-6 py-12 pb-24">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, index) => (
          <a
            href={`/post/${post.slug}`}
            class="group relative bg-white rounded-2xl border border-gray-200/60 shadow-sm hover:shadow-lg hover:border-orange-200 transition-all duration-300 overflow-hidden"
          >
            {post.feature_image ? (
              <div class="relative h-44 overflow-hidden">
                <img src={post.feature_image} alt={post.title} class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent" />
                <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-orange-500/90 backdrop-blur-sm rounded-full px-3 py-1">
                  Lektion {index + 1}
                </div>
              </div>
            ) : (
              <Fragment>
                <div class="h-1 bg-gradient-to-r from-orange-400 to-orange-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
              </Fragment>
            )}
            <div class="p-7">
              {!post.feature_image && (
                <div class="inline-flex items-center gap-2 text-xs font-semibold text-orange-600 bg-orange-50 rounded-full px-3 py-1 mb-4">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Lektion {index + 1}
                </div>
              )}
              <h2 class="text-xl font-semibold text-gray-900 leading-snug group-hover:text-orange-600 transition-colors duration-200">{post.title}</h2>
              <p class="mt-3 text-sm text-gray-500 leading-relaxed line-clamp-3">{post.excerpt}</p>
              <div class="mt-6 flex items-center justify-between">
                <div class="flex items-center gap-2 text-xs text-gray-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>{post.reading_time} Min. Lesezeit</span>
                </div>
                <div class="flex items-center gap-1 text-orange-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <span class="text-xs font-medium">Lesen</span>
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-400 mb-2">Noch keine Lektionen</h3>
        <p class="text-sm text-gray-400">Diesem Thema wurden noch keine Beiträge zugewiesen.</p>
      </div>
    )}
  </section>
</Layout>
